{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "boa/results",
    "description": "Boatrace Open API for Results",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "shimomo",
            "email": "boa@shimomo.net"
        }
    ],
    "support": {
        "issues": "https://github.com/BoatraceOpenAPI/results/issues",
        "source": "https://github.com/BoatraceOpenAPI/results"
    },
    "require": {
        "php": "^8.4",
        "bvp/scraper": "^6.0",
        "nesbot/carbon": "^2.63 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "vimeo/psalm": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "BOA\\Results\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BOA\\Results\\Tests\\": "tests/"
        }
    }
}
